# Copy this file to .env and fill in your real values
# Never commit .env to GitHub!

# Server port
PORT=5000

# MongoDB Atlas connection string (Step 5)
# Replace <username>, <password>, and <cluster> with your Atlas values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/kaamconnect?retryWrites=true&w=majority

# JWT secret for login tokens (Step 6)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Encryption key for CNIC and phone — must be 32 characters (Step 8)
ENCRYPTION_KEY=12345678901234567890123456789012

# Cloudinary credentials (Step 7)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: show detailed errors in development
NODE_ENV=development
